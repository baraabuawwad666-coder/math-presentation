<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>نسب المثلثات - عرض تفاعلي | براء أبو عواد</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body, html {
            height: 100%;
            font-family: 'Tajawal', sans-serif;
            background: linear-gradient(145deg, #e0eafc 0%, #cfdef3 100%);
            overflow: hidden;
        }

        /* الحاوية الرئيسية للشرائح */
        .slides-container {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .slide {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(2px);
            transition: top 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.05);
            overflow-y: auto;
            text-align: center;
            border-radius: 0 0 30px 30px;
        }

        .slide.active {
            top: 0;
        }

        /* تنسيق المحتوى الداخلي */
        .content {
            max-width: 1000px;
            width: 100%;
            margin: 0 auto;
            background: rgba(255,255,255,0.9);
            padding: 2rem 2.5rem;
            border-radius: 48px;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.25);
            transition: all 0.3s ease;
        }

        h1 {
            font-size: 2.8rem;
            background: linear-gradient(135deg, #1e3c72, #2b4c7c);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }

        h2 {
            font-size: 2rem;
            color: #e67e22;
            border-right: 5px solid #e67e22;
            padding-right: 20px;
            display: inline-block;
            margin-bottom: 1.5rem;
        }

        h3 {
            font-size: 1.6rem;
            color: #2c3e50;
            margin-top: 1rem;
        }

        p {
            font-size: 1.3rem;
            line-height: 1.7;
            color: #2c3e50;
            margin-bottom: 1rem;
        }

        .highlight {
            color: #2980b9;
            font-weight: 800;
            background: #eef5ff;
            padding: 0 8px;
            border-radius: 12px;
        }

        .formula-card {
            background: #fff6e5;
            padding: 15px 20px;
            margin: 15px auto;
            border-radius: 28px;
            border-right: 8px solid #f39c12;
            font-size: 1.5rem;
            font-weight: bold;
            color: #c0392b;
            width: 90%;
            max-width: 500px;
            text-align: center;
            box-shadow: 0 5px 12px rgba(0,0,0,0.05);
            transition: transform 0.2s;
        }

        .formula-card:hover {
            transform: scale(1.02);
        }

        ul {
            font-size: 1.3rem;
            text-align: right;
            background: #f8f9fc;
            padding: 20px 40px;
            border-radius: 32px;
            list-style-type: none;
            box-shadow: 0 8px 20px rgba(0,0,0,0.03);
        }
        li {
            margin-bottom: 12px;
            position: relative;
            padding-right: 28px;
        }
        li::before {
            content: "📐";
            position: absolute;
            right: 0;
            top: 0;
        }

        /* رسم المثلث SVG */
        .triangle-svg {
            background: #fef9e6;
            padding: 20px;
            border-radius: 40px;
            margin: 20px auto;
            width: fit-content;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        svg {
            max-width: 280px;
            height: auto;
        }

        /* أزرار التنقل */
        .nav-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 30px;
            flex-wrap: wrap;
        }
        .btn {
            padding: 12px 30px;
            font-size: 1.2rem;
            font-family: 'Tajawal', sans-serif;
            font-weight: bold;
            border: none;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        }
        .btn-primary {
            background: #2980b9;
            color: white;
        }
        .btn-primary:hover {
            background: #1f6391;
            transform: translateY(-3px);
        }
        .btn-secondary {
            background: #95a5a6;
            color: white;
        }
        .btn-secondary:hover {
            background: #7f8c8d;
            transform: translateY(-3px);
        }

        /* شريط التقدم */
        .progress-bar {
            position: fixed;
            bottom: 20px;
            left: 20px;
            right: 20px;
            height: 6px;
            background: #ddd;
            border-radius: 10px;
            z-index: 100;
            overflow: hidden;
        }
        .progress-fill {
            width: 20%;
            height: 100%;
            background: linear-gradient(90deg, #2980b9, #6dd5fa);
            border-radius: 10px;
            transition: width 0.3s ease;
        }
        .slide-counter {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            color: white;
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: bold;
            z-index: 100;
        }

        /* تنسيق الجوال */
        @media (max-width: 680px) {
            .content { padding: 1.5rem; }
            h1 { font-size: 2rem; }
            h2 { font-size: 1.5rem; }
            p, ul, .formula-card { font-size: 1rem; }
            .btn { padding: 8px 20px; font-size: 1rem; }
        }

        /* أيقونات وتأثيرات إضافية */
        .footer-note {
            margin-top: 20px;
            font-size: 0.9rem;
            color: #7f8c8d;
        }
    </style>
</head>
<body>

<div class="slides-container">
    <!-- الشريحة 1: البداية -->
    <div class="slide active" id="slide1">
        <div class="content">
            <h1>📐 وحدة النسب المثلثية للزوايا الحادة</h1>
            <p class="highlight" style="font-size: 1.4rem;">الرياضيات – الصف الثامن (الفصل الثاني)</p>
            <p>🇵🇸 منهاج دولة فلسطين 2026</p>
            <div style="margin: 30px 0; border-top: 2px solid #ecf0f1; padding-top: 20px;">
                <p>🎓 إعداد الطالب: <strong>براء أبو عواد</strong></p>
                <p>🧑‍🏫 إشراف الأستاذ: <strong>طارق أبو عواد</strong></p>
            </div>
            <div class="nav-buttons">
                <button class="btn btn-primary" onclick="nextSlide()">🚀 ابدأ العرض</button>
            </div>
        </div>
    </div>

    <!-- الشريحة 2: التذكير + رسم مثلث -->
    <div class="slide" id="slide2">
        <div class="content">
            <h2>📌 مرحلة التذكير</h2>
            <p>المثلث القائم الزاوية وأضلاعه بالنسبة للزاوية <strong class="highlight">θ</strong> (ثيتا):</p>
            <div class="triangle-svg">
                <svg width="260" height="220" viewBox="0 0 260 220" xmlns="http://www.w3.org/2000/svg">
                    <polygon points="30,190 220,190 30,40" fill="#f9eec1" stroke="#2c3e50" stroke-width="3" />
                    <rect x="30" y="175" width="20" height="20" fill="none" stroke="#2c3e50" stroke-width="2" />
                    <text x="50" y="200" fill="#2c3e50" font-size="14">القائمة</text>
                    <text x="120" y="205" fill="#e67e22" font-size="16">المجاور</text>
                    <text x="55" y="115" fill="#2980b9" font-size="16">المقابل</text>
                    <text x="150" y="100" fill="#16a085" font-size="16">الوتر</text>
                    <path d="M30,40 L45,55" stroke="#e67e22" stroke-width="2" />
                    <text x="50" y="60" fill="#c0392b" font-size="15">θ</text>
                </svg>
            </div>
            <ul>
                <li><strong>الزاوية القائمة</strong> = 90°</li>
                <li><strong>الوتر</strong> : أطول ضلع، مقابل للزاوية القائمة</li>
                <li><strong>المقابل</strong> : أمام الزاوية θ مباشرة</li>
                <li><strong>المجاور</strong> : الضلع الذي يلي الزاوية θ (بجانب الوتر)</li>
            </ul>
            <div class="nav-buttons">
                <button class="btn btn-secondary" onclick="prevSlide()">▲ السابق</button>
                <button class="btn btn-primary" onclick="nextSlide()">التالي ▼</button>
            </div>
        </div>
    </div>

    <!-- الشريحة 3: النسب الأساسية -->
    <div class="slide" id="slide3">
        <div class="content">
            <h2>🧠 النسب المثلثية الأساسية</h2>
            <p>النسبة المثلثية = <span class="highlight">قسمة طول ضلع على آخر</span> في المثلث القائم</p>
            <div class="formula-card">🔵 جا θ = <strong>المقابل ÷ الوتر</strong></div>
            <div class="formula-card">🟢 جتا θ = <strong>المجاور ÷ الوتر</strong></div>
            <div class="formula-card">🟠 ظا θ = <strong>المقابل ÷ المجاور</strong></div>
            <p>📝 <em>طريقة سهلة للحفظ: <strong class="highlight">جـا = مـق/وتـ ، جتـا = مـج/وتـ ، ظـا = مـق/مـج</strong></em></p>
            <div class="nav-buttons">
                <button class="btn btn-secondary" onclick="prevSlide()">▲ السابق</button>
                <button class="btn btn-primary" onclick="nextSlide()">التالي ▼</button>
            </div>
        </div>
    </div>

    <!-- الشريحة 4: تطبيق عملي -->
    <div class="slide" id="slide4">
        <div class="content">
            <h2>✏️ مثال تطبيقي</h2>
            <p>مثلث قائم: <strong>المقابل = 3 سم ، المجاور = 4 سم ، الوتر = 5 سم</strong></p>
            <div class="formula-card">📐 جا θ = 3 ÷ 5 = <span class="highlight">0.6</span></div>
            <div class="formula-card">📏 جتا θ = 4 ÷ 5 = <span class="highlight">0.8</span></div>
            <div class="formula-card">📐 ظا θ = 3 ÷ 4 = <span class="highlight">0.75</span></div>
            <p>🌟 <strong>ملاحظة:</strong> النسب المثلثية لا تمتلك وحدات قياس (أرقام مجردة).</p>
            <div class="nav-buttons">
                <button class="btn btn-secondary" onclick="prevSlide()">▲ السابق</button>
                <button class="btn btn-primary" onclick="nextSlide()">التالي ▼</button>
            </div>
        </div>
    </div>

    <!-- الشريحة 5: خلاصة وتطبيقات حياتية -->
    <div class="slide" id="slide5">
        <div class="content">
            <h2>🌍 أين نستخدم النسب المثلثية؟</h2>
            <p>✅ حساب ارتفاع الأبراج والجبال<br>
            ✅ تصميم المنحدرات والطرق<br>
            ✅ الملاحة وتحديد الاتجاهات<br>
            ✅ رسوم الحاسوب والألعاب 🎮</p>
            <div class="formula-card" style="background:#e8f8f5;">💡 "النسب المثلثية تفتح لك أبواب الهندسة والفيزياء"</div>
            <h3>🏆 شكراً لحسن استماعكم</h3>
            <p>هل لديكم أي أسئلة؟ 🙋‍♂️</p>
            <div class="nav-buttons">
                <button class="btn btn-secondary" onclick="prevSlide()">▲ العودة</button>
                <button class="btn btn-primary" onclick="restartPresentation()">🔄 إعادة العرض</button>
            </div>
        </div>
    </div>
</div>

<!-- شريط التقدم وعداد الشرائح -->
<div class="progress-bar">
    <div class="progress-fill" id="progressFill"></div>
</div>
<div class="slide-counter" id="slideCounter">الشريحة 1 / 5</div>

<script>
    let currentSlide = 1;
    const totalSlides = 5;
    const slides = document.querySelectorAll('.slide');
    
    function updateProgressAndCounter() {
        const percent = (currentSlide / totalSlides) * 100;
        document.getElementById('progressFill').style.width = percent + '%';
        document.getElementById('slideCounter').innerText = `الشريحة ${currentSlide} / ${totalSlides}`;
    }

    function showSlide(index) {
        slides.forEach((slide, i) => {
            slide.classList.remove('active');
            if (i+1 === index) {
                slide.classList.add('active');
            } else {
                slide.classList.remove('active');
            }
        });
        updateProgressAndCounter();
    }

    function nextSlide() {
        if (currentSlide < totalSlides) {
            currentSlide++;
            showSlide(currentSlide);
        }
    }

    function prevSlide() {
        if (currentSlide > 1) {
            currentSlide--;
            showSlide(currentSlide);
        }
    }

    function restartPresentation() {
        currentSlide = 1;
        showSlide(currentSlide);
    }

    // لوحة المفاتيح
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowLeft') {
            nextSlide();
        } else if (e.key === 'ArrowUp' || e.key === 'ArrowRight') {
            prevSlide();
        } else if (e.key === 'Home') {
            restartPresentation();
        }
    });

    // دعم اللمس (سحب لأعلى/لأسفل)
    let touchStartY = 0;
    document.addEventListener('touchstart', (e) => {
        touchStartY = e.changedTouches[0].screenY;
    });
    document.addEventListener('touchend', (e) => {
        const diff = touchStartY - e.changedTouches[0].screenY;
        if (diff > 40) nextSlide();      // سحب لأعلى → التالي
        if (diff < -40) prevSlide();      // سحب لأسفل → السابق
    });

    // تهيئة أولية
    updateProgressAndCounter();
</script>
</body>
</html>
